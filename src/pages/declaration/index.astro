---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getLocalBlogPostSummaries } from '../../data/local-blog';

const CATEGORY = '声明';
const posts = await getLocalBlogPostSummaries('declaration');
const pageDescription = '与产品、隐私、服务相关的正式声明与说明文档。';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`${CATEGORY} | ${SITE_TITLE}`} description={pageDescription} />
		<style>
			main {
				width: 1040px;
			}
			.section-intro {
				margin-bottom: 2.5rem;
			}
			.section-intro h1 {
				margin-bottom: 0.75rem;
				font-size: clamp(2rem, 4vw, 3rem);
			}
			.section-intro p {
				max-width: 42rem;
				margin: 0;
				color: rgb(var(--gray));
			}
			.posts {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1.5rem;
				align-items: stretch;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			.posts li {
				height: 100%;
				min-width: 0;
			}
			.card,
			.card * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			.card {
				display: flex;
				flex-direction: column;
				height: 100%;
				min-height: 100%;
				box-sizing: border-box;
				padding: 1.4rem 1.5rem;
				border: 1px solid rgba(var(--gray), 0.15);
				border-radius: 22px;
				background: rgba(255, 255, 255, 0.78);
				backdrop-filter: blur(10px);
				box-shadow: 0 16px 32px rgba(var(--gray), 0.08);
				overflow: hidden;
			}
			.card:hover {
				transform: translateY(-4px);
				border-color: rgba(var(--accent), 0.28);
				box-shadow: 0 18px 36px rgba(var(--gray), 0.16);
			}
			.card-top {
				display: flex;
				align-items: center;
				justify-content: flex-start;
				flex-wrap: wrap;
				gap: 1rem;
				margin-bottom: 1rem;
				font-size: 0.9rem;
				color: rgb(var(--gray));
			}
			.category {
				display: inline-flex;
				align-items: center;
				padding: 0.3rem 0.75rem;
				border-radius: 999px;
				background: rgba(var(--accent), 0.08);
				color: rgb(var(--accent));
				font-size: 0.85rem;
				font-weight: 700;
			}
			.title {
				margin: 0 0 0.85rem;
				color: rgb(var(--black));
				line-height: 1.25;
			}
			.description {
				margin: 0;
				color: rgb(var(--gray-dark));
				font-size: 1rem;
				line-height: 1.8;
				display: -webkit-box;
				-webkit-box-orient: vertical;
				-webkit-line-clamp: 4;
				overflow: hidden;
			}
			.card-bottom {
				margin-top: auto;
				padding-top: 1rem;
				border-top: 1px solid rgba(var(--gray), 0.12);
				display: flex;
				align-items: flex-end;
				justify-content: space-between;
				gap: 1rem;
				flex-wrap: wrap;
			}
			.tags {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
			}
			.tag {
				padding: 0.22rem 0.65rem;
				border-radius: 999px;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				font-size: 0.82rem;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.92rem;
			}
			.card:hover .title,
			.card:hover .date {
				color: rgb(var(--accent));
			}
			.empty {
				padding: 2rem;
				border-radius: 18px;
				background: rgba(var(--gray), 0.06);
				color: rgb(var(--gray-dark));
				text-align: center;
			}
			@media (max-width: 720px) {
				.section-intro {
					margin-bottom: 2rem;
				}
				.posts {
					grid-template-columns: 1fr;
					gap: 1.25rem;
				}
				.card {
					padding: 1.2rem;
				}
				.card-top,
				.card-bottom {
					align-items: flex-start;
				}
				.description {
					-webkit-line-clamp: 5;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="section-intro">
					<h1>{CATEGORY}</h1>
					<p>{pageDescription}</p>
				</div>
				{
					posts.length === 0 ? (
						<div class="empty">暂时还没有声明类文章。</div>
					) : (
						<ul class="posts">
							{posts.map((post) => (
								<li>
									<a class="card" href={`/declaration/${post.id}/`}>
										<div class="card-top">
											<span class="category">{post.category ?? CATEGORY}</span>
										</div>
										<h4 class="title">{post.title}</h4>
										<p class="description">{post.description}</p>
										<div class="card-bottom">
											<div class="tags">
												{post.tags.slice(0, 3).map((tag) => (
													<span class="tag">#{tag}</span>
												))}
											</div>
											<p class="date">
												<FormattedDate date={post.pubDate} />
											</p>
										</div>
									</a>
								</li>
							))}
						</ul>
					)
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
