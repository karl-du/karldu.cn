---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { Image } from 'astro:assets';
import ProfileImage from '../assets/karl-du-about.png';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				display: grid;
				grid-template-columns: 1.15fr 0.85fr;
				gap: 2rem;
				align-items: center;
			}
			.eyebrow {
				margin-bottom: 0.75rem;
				color: rgb(var(--accent));
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}
			h1 {
				margin-bottom: 1rem;
				font-size: clamp(2.5rem, 6vw, 4rem);
				line-height: 1.05;
			}
			.lead {
				margin-bottom: 1rem;
				font-size: 1.125rem;
				line-height: 1.8;
				color: rgb(var(--gray-dark));
			}
			.actions {
				display: flex;
				gap: 1rem;
				flex-wrap: wrap;
				margin-top: 1.5rem;
			}
			.actions a {
				padding: 0.8rem 1.2rem;
				border-radius: 999px;
				background: rgb(var(--accent));
				color: white;
				text-decoration: none;
			}
			.photo {
				position: relative;
			}
			.photo::before {
				content: '';
				position: absolute;
				inset: 1rem -1rem -1rem 1rem;
				border-radius: 24px;
				background: linear-gradient(135deg, rgba(var(--accent), 0.16), rgba(var(--accent), 0.03));
				z-index: -1;
			}
			.photo img {
				width: 100%;
				aspect-ratio: 3 / 4;
				border-radius: 24px;
				box-shadow: var(--box-shadow);
				object-fit: cover;
			}
			@media (max-width: 720px) {
				.hero {
					grid-template-columns: 1fr;
				}
				.photo {
					order: -1;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div>
					<p class="eyebrow">Personal Blog</p>
					<h1>Karl Du</h1>
					<p class="lead">
						一个 97 年的程序员，喜欢读书📚、跑步🏃‍♀️。
					</p>
					<p class="lead">
						本博客，记录生活、读书心得，还有技术心得。
					</p>
					<div class="actions">
						<a href="/post">查看博客</a>
					</div>
				</div>
				<div class="photo">
					<Image src={ProfileImage} alt="Karl Du 在湖边的个人照片" width={768} height={1024} />
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
