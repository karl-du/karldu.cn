---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
	pubDate?: Date;
	updatedDate?: Date;
	heroImage?: ImageMetadata | string;
	heroAlt?: string;
}

const { title, description, pubDate, updatedDate, heroImage, heroAlt } = Astro.props;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 1040px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}

			/* 文章目录导航 —— 固定于正文右侧，不影响正文居中 */
			.toc {
				position: fixed;
				top: 6rem;
				left: min(calc(50% + 520px + 1.5rem), calc(100vw - 240px - 1rem));
				width: 240px;
				max-height: calc(100vh - 8rem);
				overflow-y: auto;
				padding: 0.25rem 0 0.25rem 1rem;
				font-size: 0.88rem;
				line-height: 1.6;
				color: rgb(var(--gray));
				border-left: 2px solid rgba(var(--gray-light), 1);
				scrollbar-width: thin;
				z-index: 10;
			}
			.toc::-webkit-scrollbar {
				width: 6px;
			}
			.toc::-webkit-scrollbar-thumb {
				background: rgba(var(--gray-light), 1);
				border-radius: 3px;
			}
			.toc-title {
				margin: 0 0 0.6rem 0;
				font-size: 0.78rem;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: rgb(var(--gray-dark));
			}
			.toc :global(ul) {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.toc :global(li) {
				margin: 0;
				position: relative;
			}
			.toc :global(a) {
				display: block;
				padding: 0.3rem 0.5rem 0.3rem 0.75rem;
				margin-left: -2px;
				color: rgb(var(--gray));
				text-decoration: none;
				border-left: 2px solid transparent;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
				transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
			}
			.toc :global(a:hover) {
				color: rgb(var(--accent));
			}
			.toc :global(a.active) {
				color: rgb(var(--accent));
				border-left-color: rgb(var(--accent));
				font-weight: 600;
			}
			.toc :global(.toc-h3 a) {
				padding-left: 1.75rem;
				font-size: 0.84rem;
			}
			.toc :global(.toc-h4 a) {
				padding-left: 2.75rem;
				font-size: 0.8rem;
			}
			.toc:empty,
			.toc.is-empty {
				display: none;
			}

			/* 屏幕过窄时隐藏侧边目录（仅 1280px 以下隐藏） */
			@media (max-width: 1280px) {
				.toc {
					display: none;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{
					heroImage && (
						<div class="hero-image">
							{
								typeof heroImage === 'string' ? (
									<img src={heroImage} alt={heroAlt ?? ''} loading="lazy" />
								) : (
									<Image width={1020} height={510} src={heroImage} alt={heroAlt ?? ''} />
								)
							}
						</div>
					)
				}
				<div class="prose">
					<div class="title">
						{
							(pubDate || updatedDate) && (
								<div class="date">
									{pubDate && <FormattedDate date={pubDate} />}
									{
										updatedDate && (
											<div class="last-updated-on">
												Last updated on <FormattedDate date={updatedDate} />
											</div>
										)
									}
								</div>
							)
						}
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<aside class="toc is-empty" aria-label="文章目录">
			<p class="toc-title">目录</p>
			<ul></ul>
		</aside>
		<Footer />
		<script>
			const article = document.querySelector('article .prose');
			const tocEl = document.querySelector('.toc');
			const tocList = tocEl?.querySelector('ul');
			if (article && tocEl && tocList) {
				const headings = Array.from(
					article.querySelectorAll('h2, h3, h4')
				).filter((h) => !h.closest('.title')) as HTMLElement[];

				const slugify = (text: string) =>
					text
						.trim()
						.toLowerCase()
						.replace(/\s+/g, '-')
						.replace(/[^\p{L}\p{N}\-_]/gu, '');

				const items: { id: string; el: HTMLElement }[] = [];
				headings.forEach((h, i) => {
					if (!h.id) h.id = slugify(h.textContent || '') || `heading-${i}`;
					const li = document.createElement('li');
					li.className = `toc-${h.tagName.toLowerCase()}`;
					const a = document.createElement('a');
					a.href = `#${h.id}`;
					a.textContent = h.textContent || '';
					a.title = a.textContent;
					li.appendChild(a);
					tocList.appendChild(li);
					items.push({ id: h.id, el: h });
				});

				if (items.length === 0) {
					tocEl.classList.add('is-empty');
				} else {
					tocEl.classList.remove('is-empty');

					const links = new Map<string, HTMLAnchorElement>();
					tocList.querySelectorAll('a').forEach((a) => {
						const id = a.getAttribute('href')?.slice(1);
						if (id) links.set(id, a as HTMLAnchorElement);
					});

					let currentActive: HTMLAnchorElement | null = null;
					const setActive = (id: string | null) => {
						if (currentActive) currentActive.classList.remove('active');
						if (id) {
							const a = links.get(id) || null;
							if (a) {
								a.classList.add('active');
								currentActive = a;
							}
						}
					};

					const observer = new IntersectionObserver(
						(entries) => {
							const visible = entries
								.filter((e) => e.isIntersecting)
								.sort(
									(a, b) =>
										(a.target as HTMLElement).offsetTop -
										(b.target as HTMLElement).offsetTop
								);
							if (visible.length > 0) {
								setActive(visible[0].target.id);
							}
						},
						{ rootMargin: '0px 0px -70% 0px', threshold: 0 }
					);
					items.forEach((it) => observer.observe(it.el));
				}
			}
		</script>
	</body>
</html>
